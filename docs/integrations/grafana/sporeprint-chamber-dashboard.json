{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "timeseries",
      "title": "Temperature (°C)",
      "datasource": { "type": "prometheus", "uid": "prom" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sporeprint_node_temperature_celsius",
          "legendFormat": "{{node_id}} (chamber {{chamber_id}})",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "timeseries",
      "title": "Humidity (%)",
      "datasource": { "type": "prometheus", "uid": "prom" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "palette-classic" },
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sporeprint_node_humidity_percent",
          "legendFormat": "{{node_id}} (chamber {{chamber_id}})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CO₂ (ppm)",
      "datasource": { "type": "prometheus", "uid": "prom" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "sporeprint_node_co2_ppm",
          "legendFormat": "{{node_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Active grow sessions",
      "datasource": { "type": "prometheus", "uid": "prom" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "count(sporeprint_chamber_session_active == 1)",
          "legendFormat": "Active",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Actuator events / 5 min",
      "datasource": { "type": "prometheus", "uid": "prom" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "lineWidth": 1 }
        }
      },
      "targets": [
        {
          "expr": "increase(sporeprint_actuator_event_count[5m])",
          "legendFormat": "{{channel}} {{action}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Contaminations (lifetime, this Pi)",
      "datasource": { "type": "prometheus", "uid": "prom" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 24 },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "sum(sporeprint_contamination_events_total)",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["sporeprint", "mushroom", "cultivation"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "SporePrint Chambers",
  "uid": "sporeprint-chambers",
  "version": 1,
  "weekStart": ""
}
