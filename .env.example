# SporePrint Configuration
# Copy to .env and fill in your values: cp .env.example .env

# Database
SPOREPRINT_DATABASE_PATH=data/db/sporeprint.db

# MQTT Broker — credentials generated by setup.sh on first run. If blank,
# the Pi connects anonymously; that only works when the broker also has
# allow_anonymous=true (development). Production always uses credentials.
SPOREPRINT_MQTT_HOST=localhost
SPOREPRINT_MQTT_PORT=1883
SPOREPRINT_MQTT_USERNAME=
SPOREPRINT_MQTT_PASSWORD=

# Notifications (ntfy)
SPOREPRINT_NTFY_URL=http://localhost:8080
SPOREPRINT_NTFY_TOPIC=sporeprint

# Vision
SPOREPRINT_VISION_STORAGE=data/vision

# Claude API (required for vision analysis + builder's assistant)
SPOREPRINT_CLAUDE_API_KEY=

# Weather (default: Open-Meteo, no key needed — just set lat/lon)
# Providers: "openmeteo" (default, free), "openweathermap" (needs key), "nws" (US only, free)
SPOREPRINT_WEATHER_PROVIDER=openmeteo
SPOREPRINT_WEATHER_API_KEY=
SPOREPRINT_WEATHER_LAT=
SPOREPRINT_WEATHER_LON=
SPOREPRINT_WEATHER_POLL_MINUTES=10

# Cloud connector (opt-in — for mobile app remote access)
SPOREPRINT_CLOUD_URL=
SPOREPRINT_CLOUD_TOKEN=
SPOREPRINT_CLOUD_DEVICE_ID=

# Backend API key — all /api/* requests and Socket.IO connects must present
# `Authorization: Bearer <SPOREPRINT_API_KEY>`. Generated by setup.sh on first
# run. Leave blank only for local development. See docs/auth.md.
SPOREPRINT_API_KEY=

# Server
SPOREPRINT_HOST=0.0.0.0
SPOREPRINT_PORT=8000
