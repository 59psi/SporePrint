# SporePrint Configuration
# Copy to .env and fill in your values: cp .env.example .env

# Database
SPOREPRINT_DATABASE_PATH=data/db/sporeprint.db

# MQTT Broker
SPOREPRINT_MQTT_HOST=localhost
SPOREPRINT_MQTT_PORT=1883

# Notifications (ntfy)
SPOREPRINT_NTFY_URL=http://localhost:8080
SPOREPRINT_NTFY_TOPIC=sporeprint

# Vision
SPOREPRINT_VISION_STORAGE=data/vision

# Claude API (required for vision analysis + builder's assistant)
SPOREPRINT_CLAUDE_API_KEY=

# Server
SPOREPRINT_HOST=0.0.0.0
SPOREPRINT_PORT=8000
